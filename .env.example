# Deployment mode. Use self-hosted for local development and community installs.
DEPLOYMENT_MODE=self-hosted

# Database. Local development defaults match docker-compose.yml.
DATABASE_URL=postgres://reviewinbox:reviewinbox@localhost:5432/reviewinbox

# Migrations. Keep false for development and multi-instance deployments; run pnpm db:migrate manually.
RUN_DB_MIGRATIONS_ON_STARTUP=false

# API listener. The Angular dev server proxies /api to this origin.
API_HOST=127.0.0.1
API_PORT=3000

# Public app origin used in links and security checks.
APP_PUBLIC_URL=http://localhost:4200

# Better Auth. Generate BETTER_AUTH_SECRET with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://127.0.0.1:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Store Credential encryption. Required before saving Store Credentials.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# AI drafting. Disabled means ReviewInbox runs without autogenerated Reply Drafts.
# Set AI_PROVIDER=openai-compatible plus AI_MODEL and AI_API_KEY to enable AI-generated Reply Drafts.
AI_PROVIDER=disabled
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=

# Invitation email delivery. Configure both MAIL_FROM and SMTP_HOST to enable email sending.
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Worker scheduling for automatic Store Connection sync jobs.
AUTO_SYNC_REVIEWS_ENABLED=true
AUTO_SYNC_REVIEWS_SPREAD_WINDOW_MINUTES=60

# Local uploads. Used for organization logos and other local file storage.
UPLOAD_LOCAL_DIR=volumes/uploads

# S3-compatible uploads. Leave blank unless replacing local uploads with object storage.
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

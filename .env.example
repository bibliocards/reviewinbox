DATABASE_URL=postgres://reviewinbox:reviewinbox@localhost:5432/reviewinbox
REVIEWINBOX_DEPLOYMENT_MODE=self-hosted

# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-value

# Generate with: pnpm exec auth secret
BETTER_AUTH_SECRET=replace-with-better-auth-secret
BETTER_AUTH_URL=http://localhost:5173

# Email/password signup is disabled until Owner onboarding and email verification are implemented.

{
  "name": "ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/ai/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "swc packages/ai/src -d dist/packages/ai --strip-leading-paths"
      },
      "outputs": ["{workspaceRoot}/dist/packages/ai"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/ai/tsconfig.lib.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run packages/ai/src --passWithNoTests"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome lint packages/ai"
      }
    }
  },
  "tags": ["scope:shared", "type:ai"]
}

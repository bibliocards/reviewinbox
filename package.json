{
  "name": "reviewinbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "serve": "nx run-many -t serve -p api web --tui=false",
    "serve:api": "nx serve api",
    "serve:worker": "nx serve worker",
    "serve:web": "nx serve web",
    "serve:site": "nx serve site",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:clear": "docker compose exec -T postgres psql -U reviewinbox -d reviewinbox -c \"DROP SCHEMA IF EXISTS drizzle CASCADE; DROP SCHEMA IF EXISTS public CASCADE; CREATE SCHEMA public;\"",
    "db:reset": "pnpm db:clear && pnpm db:migrate",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@angular/common": "21.2.16",
    "@angular/compiler": "21.2.16",
    "@angular/core": "21.2.16",
    "@angular/forms": "21.2.16",
    "@angular/platform-browser": "21.2.16",
    "@angular/router": "21.2.16",
    "@angular/service-worker": "21.2.16",
    "@aws-sdk/client-s3": "^3.1071.0",
    "@better-auth/stripe": "^1.6.20",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hono/node-server": "^1.19.6",
    "@jsverse/transloco": "^8.4.0",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.3.1",
    "ai": "^6.0.208",
    "better-auth": "^1.6.20",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.7",
    "ngx-better-auth": "^1.6.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.16.3",
    "pg-boss": "^12.19.1",
    "postcss": "^8.5.15",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.2",
    "tailwindcss": "^4.3.1",
    "tailwindcss-primeui": "^0.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.16",
    "@angular/build": "21.2.16",
    "@angular/cli": "21.2.16",
    "@angular/compiler-cli": "21.2.16",
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.40.0",
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.5.0",
    "@nx/angular": "22.7.5",
    "@nx/js": "22.7.5",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.0.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.6",
    "astro": "^6.4.8",
    "drizzle-kit": "^0.31.8",
    "nx": "22.7.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  }
}

# ReviewInbox image version. Pin this to a GitHub Release version; I do not recommend to use latest.
REVIEWINBOX_VERSION=0.1.0

# Public origin. Use the HTTPS URL that users open in their browser.
APP_PUBLIC_URL=https://reviewinbox.example.com
BETTER_AUTH_URL=https://reviewinbox.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://reviewinbox.example.com

# Required secrets. Generate both before starting the stack.
# openssl rand -base64 32
BETTER_AUTH_SECRET=
APP_ENCRYPTION_KEY=

# Postgres container credentials. Generate a strong password.
POSTGRES_DB=reviewinbox
POSTGRES_USER=reviewinbox
POSTGRES_PASSWORD=

# Reply Draft worker enqueueing. Set true on the API when the worker is deployed with AI drafting enabled.
REPLY_DRAFT_WORKER_ENABLED=false

# AI drafting. Worker-only. Keep disabled to run without autogenerated Reply Drafts.
# Set AI_PROVIDER=openai-compatible plus AI_MODEL and AI_API_KEY on the worker to enable AI-generated Reply Drafts.
AI_PROVIDER=disabled
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=

########################################################################################################################
# Local ports exposed on the VPS loopback interface for your reverse proxy.
REVIEWINBOX_WEB_PORT=8080
REVIEWINBOX_API_PORT=3000

# Invitation email delivery. Required only when you want ReviewInbox to send emails.
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Worker scheduling.
AUTO_SYNC_REVIEWS_ENABLED=true
AUTO_SYNC_REVIEWS_SPREAD_WINDOW_MINUTES=60

# Local uploads. Keep this default for Docker Compose named volume storage.
UPLOAD_LOCAL_DIR=volumes/uploads

# S3-compatible uploads. Leave blank unless using object storage.
S3_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Frontend runtime config. Defaults support a single public domain with /api routed to the API.
REVIEWINBOX_API_URL=
REVIEWINBOX_AUTH_BASE_PATH=/api/auth
REVIEWINBOX_AUTH_GOOGLE_ENABLED=false
REVIEWINBOX_AUTH_SSO_ENABLED=false
